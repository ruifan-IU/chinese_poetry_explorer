// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Dynasty {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  authors   Author[]
  texts     Text[]
}

model Poet {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  introduction String?
  dynastyId    Int?
  dynasty      Dynasty? @relation(fields: [dynastyId], references: [id])
  texts        Text[]
}

model Text {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  contentHash String   @unique
  annotation  String?
  comments    String?
  translation String?
  authorId    Int
  dynastyId   Int
  author      Author   @relation(fields: [authorId], references: [id])
  dynasty     Dynasty  @relation(fields: [dynastyId], references: [id])
  textTypes   TextType[]
}

model Type {
  id    Int    @id @default(autoincrement())
  name  String @unique
  textTypes TextType[]
}

model TextType {
  textId Int
  typeId Int
  text   Text @relation(fields: [textId], references: [id])
  type   Type @relation(fields: [typeId], references: [id])

  @@id([textId, typeId])
}

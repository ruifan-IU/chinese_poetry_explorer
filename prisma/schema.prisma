// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
  output   = "../lib/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dynasty {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  poets     Poet[]
  poems     Poem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poet {
  id           Int      @id @default(autoincrement())
  stars       Int      @default(0)
  name         String   @unique
  image       String?
  summary String?
  introduction   String?
  dynastyId    Int?
  dynasty      Dynasty? @relation(fields: [dynastyId], references: [id])
  poems        Poem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dynastyId])
  @@index([name])
  @@index([stars])
}

enum PoemType {
  shi
  ci
  wen
}

model Poem {
  id          Int      @id @default(autoincrement())
  title       String
  stars       Int     @default(0)
  content     String
  contentHash String   @unique
  background  String?
  comments    String?
  translation String?
  type        PoemType @default(shi)
  poetId      Int
  dynastyId   Int
  poet        Poet     @relation(fields: [poetId], references: [id])
  dynasty     Dynasty  @relation(fields: [dynastyId], references: [id])
  tags        Tag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([title])
  @@index([poetId])
  @@index([dynastyId])
  @@index([stars])
  @@index([type])
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  poems Poem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
